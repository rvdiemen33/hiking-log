root = true

[*]
indent_style = space
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_size = 4

# Using-directives bovenaan, gesorteerd, System eerst
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Vermijd onnodige 'this.'
dotnet_style_qualification_for_field = false
dotnet_style_qualification_for_property = false
dotnet_style_qualification_for_method = false
dotnet_style_qualification_for_event = false

# Gebruik ingebouwde typenamen (int, string, bool — niet Int32, String, Boolean)
dotnet_style_predefined_type_for_locals_parameters_members = true
dotnet_style_predefined_type_for_member_access = true

# var alleen als het type evident is
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_constructors = false:silent

# Accolades altijd (ook bij één regel)
csharp_prefer_braces = true:warning

# Namespace als file-scoped
csharp_style_namespace_declarations = file_scoped:warning

# Nieuwe regel voor opening brace
csharp_new_line_before_open_brace = all

# Primary constructors — gebruik waar van toepassing (C# 13)
csharp_style_prefer_primary_constructors = true:suggestion

[*.{csproj,props,targets}]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
